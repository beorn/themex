{
  "name": "themex",
  "version": "0.1.0",
  "description": "Universal color themes for any platform — terminal, web, native",
  "keywords": [
    "catppuccin",
    "color",
    "dracula",
    "nord",
    "palette",
    "solarized",
    "terminal",
    "theme",
    "tui"
  ],
  "homepage": "https://github.com/beorn/themex#readme",
  "bugs": {
    "url": "https://github.com/beorn/themex/issues"
  },
  "license": "MIT",
  "author": "beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/themex.git"
  },
  "type": "module",
  "sideEffects": ["./src/state.ts"],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "themex": "./src/cli.ts"
  },
  "scripts": {
    "cli": "bun src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "ci": "bun run typecheck && bun test",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.7.3"
  }
}
