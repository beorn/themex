{
  "name": "swatch",
  "version": "0.1.0",
  "description": "Universal color themes for any platform — terminal, web, native",
  "keywords": [
    "catppuccin",
    "color",
    "dracula",
    "nord",
    "palette",
    "solarized",
    "terminal",
    "theme",
    "tui"
  ],
  "homepage": "https://github.com/beorn/swatch#readme",
  "bugs": {
    "url": "https://github.com/beorn/swatch/issues"
  },
  "license": "MIT",
  "author": "beorn",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/swatch.git"
  },
  "bin": {
    "swatch": "./src/cli.ts"
  },
  "type": "module",
  "sideEffects": [
    "./src/state.ts"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "cli": "bun src/cli.ts",
    "view": "bun src/view.tsx",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "ci": "bun run typecheck && bun test",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "typescript": "^5.7.3",
    "vitepress": "^1.6.4"
  },
  "peerDependencies": {
    "@hightea/term": "*"
  },
  "peerDependenciesMeta": {
    "@hightea/term": {
      "optional": true
    }
  }
}
